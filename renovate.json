{
  "extends": [
    "github>harvester/dependency-automation:renovate"
  ],
  "baseBranchPatterns": [
    "main",
    "release-1.14",
    "release-1.15"
  ],
  "packageRules": [
    {
      "description": "Release branches: only patch and security",
      "matchBaseBranches": [
        "release-1.14",
        "release-1.15"
      ],
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "enabled": false
    },
    {
      "description": "Label PRs with target branch name",
      "matchBaseBranches": [
        "release-1.14",
        "release-1.15"
      ],
      "addLabels": [
        "{{baseBranch}}"
      ]
    }
  ]
}